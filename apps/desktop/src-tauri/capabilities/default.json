{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "permissions": [
    "oauth:allow-cancel",
    "oauth:allow-start",
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "steam://*" }, { "url": "https://app.notion.com/*" }, { "url": "https://www.notion.so/*" }]
    },
    "core:window:allow-close",
    "core:window:allow-destroy",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://translation-tool-back.deltarune-fr.com/*"
        },
        {
          "url": "https://deltarune-fr.com/*"
        },
        {
          "url": "https://api.github.com/*"
        },
        {
          "url": "https://codeload.github.com/*"
        },
        {
          "url": "http://localhost:1420/*"
        },
        {
          "url": "http://localhost:3000/*"
        }
      ]
    },
    "shell:default",
    "store:default",
    "core:webview:allow-set-webview-zoom",
    "dialog:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "fs:allow-rename",
    {
      "identifier": "fs:scope",
      "allow": ["**"]
    },
    "fs:allow-seek",
    "fs:allow-read",
    "fs:allow-exists",
    "log:default",
    "os:default",
    "clipboard-manager:allow-read-image",
    "core:image:allow-rgba",
    "core:image:allow-size"
  ]
}
